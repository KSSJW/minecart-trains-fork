{
	"schemaVersion": 1,
	"id": "minecart-trains-fork",
	"version": "1.20.5-beta.1",
	"name": "Minecart Trains Fork",
	"description": "Forked from Minecart Trains, This mod adds additional mechanics to make minecart transportation more fun and useful as a train system!",
	"authors": [
		"LarsenR KSSJW"
	],
	"contact": {
		"homepage": "https://github.com/KSSJW/minecart-trains-fork",
		"issues": "https://github.com/KSSJW/minecart-trains-fork/issues",
		"sources": "https://github.com/KSSJW/minecart-trains-fork"
	},
	"license": "GPL-3.0",
	"icon": "assets/minecart-trains/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"de.larsensmods.mctrains.MinecartTrains"
		],
		"client": [
			"de.larsensmods.mctrains.MinecartTrainsClient"
		],
		"fabric-datagen": [
			"de.larsensmods.mctrains.MinecartTrainsDataGenerator"
		]
	},
	"custom": {
		"loom:injected_interfaces": {
			"net/minecraft/class_1688": [
				"de/larsensmods/mctrains/interfaces/IChainable"
			]
		}
	},
	"mixins": [
		"minecart-trains.mixins.json",
		{
			"config": "minecart-trains.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.17.0",
		"minecraft": ">=1.20.5",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
	}
}
